{
  "name": "@ik-photos/back",
  "private": true,
  "license": "MIT",
  "version": "0.0.0",
  "scripts": {
    "build": "nest build",
    "build:bundle": "rm -rf dist tsconfig.tsbuildinfo bundle && nest build && ncc build dist/main.js -o bundle -m -e sharp",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "lint": "tsc --noEmit",
    "db:push": "dotenv -e ../../.env -- drizzle-kit push",
    "db:pull": "dotenv -e ../../.env -- drizzle-kit pull",
    "db:generate": "dotenv -e ../../.env -- drizzle-kit generate",
    "db:migrate": "dotenv -e ../../.env -- drizzle-kit migrate",
    "db:studio": "dotenv -e ../../.env -- drizzle-kit studio"
  },
  "dependencies": {
    "@ik-photos/shared": "workspace:*",
    "@nestjs/common": "^11.1.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.1.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.0",
    "@nestjs/platform-express": "^11.1.0",
    "@nestjs/schedule": "^5.0.0",
    "@nestjs/throttler": "^6.5.0",
    "@types/archiver": "^7.0.0",
    "@types/compression": "^1.8.1",
    "archiver": "^7.0.1",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "drizzle-orm": "^0.44.0",
    "exifr": "^7.1.3",
    "joi": "^17.13.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.18.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^5.0.6",
    "@types/node": "^22.15.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.16.0",
    "@vercel/ncc": "^0.38.3",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.0",
    "typescript": "~5.9.3"
  }
}
